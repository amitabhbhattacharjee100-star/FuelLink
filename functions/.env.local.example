# Cloud Functions Environment Variables
# Copy this file to functions/.env.local and fill in actual values

# RapidAPI Gas Price API Key
# Get from: https://rapidapi.com/DeveloperAmoebas/api/gas-price
GAS_PRICE_API_KEY=your_rapidapi_key_here

# SendGrid API Key for Email Delivery
# Get from: https://sendgrid.com/
# Must have Mail Send permission
SENDGRID_API_KEY=SG.your_sendgrid_key_here

# Optional: SendGrid Sender Email (defaults to daily@fuellink.app)
SENDGRID_FROM_EMAIL=daily@fuellink.app

# Optional: Mailgun Alternative (use instead of SendGrid)
# MAILGUN_DOMAIN=fuellink.mailgun.org
# MAILGUN_KEY=your_mailgun_key

# Firebase Configuration (auto-populated by flutterfire configure)
# These are typically set via Firebase Console
FIREBASE_PROJECT_ID=fuellink-ontario
FIREBASE_DATABASE_URL=https://fuellink-ontario.firebaseio.com

# Optional: Set function memory allocation (default 256MB)
# Valid values: 128MB, 256MB, 512MB, 1GB, 2GB, 4GB
# FUNCTION_MEMORY=512MB

# Optional: Enable debug logging
# DEBUG=fuellink:*

# ============================================================================
# SETUP INSTRUCTIONS:
# ============================================================================
#
# 1. Copy values from your services:
#    - RapidAPI: Dashboard > API key > Copy
#    - SendGrid: Settings > API Keys > Create Key (Mail Send)
#
# 2. Load environment into Firebase:
#    firebase functions:config:set \
#      sendgrid.api_key="SG.xxxx" \
#      sendgrid.from_email="daily@fuellink.app"
#
# 3. Deploy:
#    firebase deploy --only functions
#
# 4. Monitor:
#    firebase functions:log --follow
#
# ============================================================================
