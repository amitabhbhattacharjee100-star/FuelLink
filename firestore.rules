rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========================================================================
    // USERS COLLECTION - User profiles and subscription preferences
    // ========================================================================
    match /users/{userId} {
      // Read: Only the authenticated user can read their own profile
      allow read: if request.auth.uid == userId;
      
      // Write: Only the authenticated user can write their own profile
      allow write: if request.auth.uid == userId;
      
      // Admin read-only (for Cloud Functions)
      allow read: if false; // Cloud Functions use Admin SDK (bypasses security rules)
    }
    
    // ========================================================================
    // EMAIL LOGS COLLECTION - Analytics of email sends
    // ========================================================================
    match /emailLogs/{logId} {
      // Users can read their own analytics (future feature)
      allow read: if request.auth != null;
      
      // Only Cloud Functions can write (via Admin SDK)
      allow write: if false;
    }
    
    // ========================================================================
    // PRICE HISTORY COLLECTION - Historical gas price snapshots
    // ========================================================================
    match /priceHistory/{historyId} {
      // Authenticated users can read historical data for charts
      allow read: if request.auth != null;
      
      // Only Cloud Functions can write (via Admin SDK)
      allow write: if false;
    }
    
    // ========================================================================
    // ERROR LOGS COLLECTION - Function error tracking
    // ========================================================================
    match /errorLogs/{errorId} {
      // No user access - internal monitoring only
      allow read, write: if false;
    }
    
    // ========================================================================
    // CATCH-ALL - Deny everything else by default
    // ========================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
